# API Base URL - Đường dẫn API chính của Backend (Thêm /api/v1 ở cuối)
# Ví dụ: http://localhost:8080/api/v1 hoặc https://domain-cua-ban.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# OAuth Base URL - Đường dẫn cho chức năng Đăng nhập bằng Google/Github (Không có /api/v1 ở cuối)
# Ví dụ: http://localhost:8080 hoặc https://domain-cua-ban.com
# .env trong tet-gift-commerce-frontend
VITE_OAUTH_URL=http://localhost:8080
